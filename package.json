{
  "name": "openscoreboard",
  "version": "0.1.0",
  "description": "Open source sports scoreboard — no database required",
  "main": "dist/server.js",
  "scripts": {
    "dev:client": "vite",
    "dev:server": "npx tsx watch server.ts",
    "dev": "concurrently \"npm run dev:server\" \"sleep 3 && npm run dev:client\"",
    "build": "vite build && tsc --project tsconfig.server.json",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "marked": "^18.0.5",
    "pinia": "^2.1.0",
    "vue": "^3.4.5",
    "vue-i18n": "^11.4.5",
    "vue-router": "^4.3.0",
    "ws": "^8.16.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.2",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/compiler-sfc": "^3.4.5",
    "concurrently": "^10.0.3",
    "daisyui": "^5.5.23",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "wait-on": "^9.0.10"
  }
}
